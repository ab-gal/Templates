-box;&quot;&gt;&lt;span class=&quot;ng-star-inserted&quot; style=&quot;animation: auto ease 0s 1 normal none running none !important; transition: none !important; box-sizing: border-box;&quot;&gt;Standard term:&lt;/span&gt;&lt;/strong&gt;&lt;span class=&quot;ng-star-inserted&quot; style=&quot;animation: auto ease 0s 1 normal none running none !important; transition: none !important; box-sizing: border-box;&quot;&gt;&amp;nbsp;Independent Variable.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li class=&quot;ng-star-inserted&quot; style=&quot;box-sizing: border-box; font-optical-sizing: auto; animation: auto ease 0s 1 normal none running none !important; transition: none !important;&quot;&gt;&lt;p class=&quot;ng-star-inserted&quot; style=&quot;box-sizing: border-box; font-optical-sizing: auto; margin-bottom: 3px; margin-top: 0px; animation: auto ease 0s 1 normal none running none !important; transition: none !important;&quot;&gt;&lt;strong class=&quot;ng-star-inserted&quot; style=&quot;animation: auto ease 0s 1 normal none running none !important; transition: none !important; box-sizing: border-box;&quot;&gt;&lt;span class=&quot;ng-star-inserted&quot; style=&quot;animation: auto ease 0s 1 normal none running none !important; transition: none !important; box-sizing: border-box;&quot;&gt;What it means:&lt;/span&gt;&lt;/strong&gt;&lt;span class=&quot;ng-star-inserted&quot; style=&quot;animation: auto ease 0s 1 normal none running none !important; transition: none !important; box-sizing: border-box;&quot;&gt;&amp;nbsp;This is the variable that puts your data into&amp;nbsp;&lt;/span&gt;&lt;strong class=&quot;ng-star-inserted&quot; style=&quot;animation: auto ease 0s 1 normal none running none !important; transition: none !important; box-sizing: border-box;&quot;&gt;&lt;span class=&quot;ng-star-inserted&quot; style=&quot;animation: auto ease 0s 1 normal none running none !important; transition: none !important; box-sizing: border-box;&quot;&gt;groups&lt;/span&gt;&lt;/strong&gt;&lt;span class=&quot;ng-star-inserted&quot; style=&quot;animation: auto ease 0s 1 normal none running none !important; transition: none !important; box-sizing: border-box;&quot;&gt;&amp;nbsp;or categories. It is the &quot;cause&quot; or the factor you are testing to see if it makes a difference.&amp;nbsp;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div style=&quot;&quot;&gt;&lt;h3 class=&quot;ng-star-inserted&quot; style=&quot;box-sizing: border-box; margin: 0px; color: rgb(26, 28, 30); font-family: Inter, sans-serif; line-height: 100%; animation: auto ease 0s 1 normal none running none !important; transition: none !important;&quot;&gt;&lt;span class=&quot;ng-star-inserted&quot; style=&quot;box-sizing: border-box; animation: auto ease 0s 1 normal none running none !important; transition: none !important;&quot;&gt;&lt;font style=&quot;font-size: 10px; line-height: 100%;&quot;&gt;Outcome Variable&lt;/font&gt;&lt;/span&gt;&lt;/h3&gt;&lt;ul class=&quot;ng-star-inserted&quot; style=&quot;font-size: 9px; box-sizing: border-box; padding-left: 24px; color: rgb(26, 28, 30); font-family: Inter, sans-serif; line-height: 100%; animation: auto ease 0s 1 normal none running none !important; transition: none !important;&quot;&gt;&lt;li class=&quot;ng-star-inserted&quot; style=&quot;box-sizing: border-box; font-optical-sizing: auto; animation: auto ease 0s 1 normal none running none !important; transition: none !important;&quot;&gt;&lt;p class=&quot;ng-star-inserted&quot; style=&quot;box-sizing: border-box; font-optical-sizing: auto; margin-bottom: 3px; margin-top: 0px; animation: auto ease 0s 1 normal none running none !important; transition: none !important;&quot;&gt;&lt;strong class=&quot;ng-star-inserted&quot; style=&quot;animation: auto ease 0s 1 normal none running none !important; transition: none !important; box-sizing: border-box;&quot;&gt;Standard term:&lt;/strong&gt;&lt;span class=&quot;ng-star-inserted&quot; style=&quot;animation: auto ease 0s 1 normal none running none !important; transition: none !important; box-sizing: border-box;&quot;&gt;&amp;nbsp;Dependent Variable.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li class=&quot;ng-star-inserted&quot; style=&quot;box-sizing: border-box; font-optical-sizing: auto; animation: auto ease 0s 1 normal none running none !important; transition: none !important;&quot;&gt;&lt;p class=&quot;ng-star-inserted&quot; style=&quot;box-sizing: border-box; font-optical-sizing: auto; margin-bottom: 3px; margin-top: 0px; animation: auto ease 0s 1 normal none running none !important; transition: none !important;&quot;&gt;&lt;strong class=&quot;ng-star-inserted&quot; style=&quot;box-sizing: border-box; animation: auto ease 0s 1 normal none running none !important; transition: none !important;&quot;&gt;What it means here:&lt;/strong&gt;&lt;span class=&quot;ng-star-inserted&quot; style=&quot;box-sizing: border-box; animation: auto ease 0s 1 normal none running none !important; transition: none !important;&quot;&gt;&amp;nbsp;This is the variable you are actually&amp;nbsp;&lt;/span&gt;&lt;strong class=&quot;ng-star-inserted&quot; style=&quot;box-sizing: border-box; animation: auto ease 0s 1 normal none running none !important; transition: none !important;&quot;&gt;measuring&lt;/strong&gt;&lt;span class=&quot;ng-star-inserted&quot; style=&quot;box-sizing: border-box; animation: auto ease 0s 1 normal none running none !important; transition: none !important;&quot;&gt;. It is the &quot;effect&quot; or the result that changes based on the group.&lt;br&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/font&gt;" vertex="1">
