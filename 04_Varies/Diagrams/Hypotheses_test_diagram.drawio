        <mxCell id="7nWFPXopERBmQTWbtrVL-198" parent="7nWFPXopERBmQTWbtrVL-192" style="connectable=0;recursiveResize=0;strokeColor=none;fillColor=none;align=center;whiteSpace=wrap;html=1;rowspan=2;colspan=1;" value="&lt;span style=&quot;font-size: 10px;&quot;&gt;Doesn&#39;t indicate&amp;nbsp;&lt;/span&gt;&lt;b style=&quot;font-size: 10px;&quot;&gt;what&amp;nbsp;&lt;/b&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;is significant, but&amp;nbsp;&lt;/span&gt;&lt;b style=&quot;font-size: 10px;&quot;&gt;if there&lt;/b&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&amp;nbsp;is a significance&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-size: 9px; font-family: monospace; text-align: start; white-space-collapse: preserve; background-color: transparent;&quot;&gt;&lt;font color=&quot;#0f0f10&quot;&gt;&amp;lt;stats.kruskal(&lt;/font&gt;&lt;b style=&quot;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(153, 0, 0), rgb(255, 255, 255));&quot;&gt;A, B, C&lt;/font&gt;&lt;/b&gt;&lt;font color=&quot;#0f0f10&quot;&gt;)&amp;gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space-collapse: preserve; background-color: transparent; font-size: 9px; color: rgb(15, 15, 16); font-family: monospace; text-align: start;&quot;&gt;&amp;lt;anosim(&lt;/span&gt;&lt;span class=&quot;hljs-string&quot; style=&quot;white-space-collapse: preserve; background-color: transparent; font-size: 9px; box-sizing: border-box; font-family: monospace; text-align: start; animation: auto ease 0s 1 normal none running none !important; transition: none !important;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 76, 153), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;distance_matrix&lt;/b&gt;, &lt;/font&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;grouping =&lt;/font&gt;&lt;font style=&quot;color: light-dark(rgb(0, 76, 153), rgb(255, 255, 255));&quot;&gt; &lt;/font&gt;&lt;font style=&quot;color: light-dark(rgb(153, 0, 0), rgb(255, 255, 2