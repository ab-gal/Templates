        <mxCell id="ttZCbK3ra_AwcMFaCHn2-49" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div&gt;&lt;font style=&quot;font-size: 9px; line-height: 100%;&quot;&gt;stat, p_value = stats.t_test_ind (sample1, sample2, &lt;b&gt;&lt;font style=&quot;color: rgb(255, 128, 0);&quot;&gt;alternative&lt;/font&gt;&lt;/b&gt;&lt;font style=&quot;color: rgb(255, 128, 0);&quot;&gt;= two-sided&lt;/font&gt;)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 9px; line-height: 100%;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;H0: sample1 = sample2 |&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center;&quot;&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;H0: p&amp;gt;0.05&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 9px; line-height: 100%;&quot;&gt;&lt;font style=&quot;color: rgb(255, 128, 0);&quot;&gt;&lt;b&gt;H1&lt;/b&gt;: sample1 != sample2 |&amp;nbsp;&lt;/font&gt;&lt;/font&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center;&quot;&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;&lt;font style=&quot;color: rgb(255, 128, 0);&quot;&gt;H1: p&amp;lt;0.05&lt;/font&gt;&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="50.3" width="310" x="1340" y="50.00000000000001" as="geometry" />
        </mxCell>
