        <mxCell id="7nWFPXopERBmQTWbtrVL-149" parent="7nWFPXopERBmQTWbtrVL-143" style="connectable=0;recursiveResize=0;strokeColor=none;fillColor=none;align=left;whiteSpace=wrap;html=1;" value="&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;DM Mono&amp;quot;, monospace; font-size: 9px;&quot;&gt;r_coef, p_value = stats.spearmanr (&lt;/span&gt;&lt;b style=&quot;font-family: &amp;quot;DM Mono&amp;quot;, monospace; font-size: 9px;&quot;&gt;Variable A&lt;/b&gt;&lt;span style=&quot;font-family: &amp;quot;DM Mono&amp;quot;, monospace; font-size: 9px;&quot;&gt;,&amp;nbsp;&lt;/span&gt;&lt;b style=&quot;font-family: &amp;quot;DM Mono&amp;quot;, monospace; font-size: 9px;&quot;&gt;Variable B&lt;/b&gt;&lt;span style=&quot;font-family: &amp;quot;DM Mono&amp;quot;, monospace; font-size: 9px;&quot;&gt;)&lt;/span&gt;&lt;/font&gt;" vertex="1">
