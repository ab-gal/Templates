        </mxCell>
        <mxCell id="ttZCbK3ra_AwcMFaCHn2-169" parent="ttZCbK3ra_AwcMFaCHn2-163" style="connectable=0;recursiveResize=0;strokeColor=none;fillColor=none;align=left;whiteSpace=wrap;html=1;rowspan=2;colspan=1;" value="&lt;span style=&quot;font-family: &amp;quot;DM Mono&amp;quot;, monospace;&quot;&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;r_coef, p_value = stats.pearsonr(&lt;b style=&quot;&quot;&gt;Outcome1&lt;/b&gt;, &lt;b style=&quot;&quot;&gt;Outcome2&lt;/b&gt;)&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;" vertex="1">
