        <mxCell id="ttZCbK3ra_AwcMFaCHn2-7" parent="xCRE8wccOKQfFn8-C-6z-188" style="connectable=0;recursiveResize=0;strokeColor=none;fillColor=none;align=center;whiteSpace=wrap;html=1;" value="&lt;div&gt;&lt;span style=&quot;font-size: 9px; background-color: transparent; white-space-collapse: preserve; color: rgb(15, 15, 16); font-family: monospace; text-align: start;&quot;&gt;MANOVA.from_formula(&lt;/span&gt;&lt;span class=&quot;hljs-string&quot; style=&quot;font-size: 9px; background-color: transparent; white-space-collapse: preserve; box-sizing: border-box; color: rgb(3, 47, 98); font-family: monospace; text-align: start; animation: auto ease 0s 1 normal none running none !important; transition: none !important;&quot;&gt;&#39;Satisfaction + Spend ~ Group&#39;&lt;/span&gt;&lt;span style=&quot;font-size: 9px; background-color: transparent; white-space-collapse: preserve; color: rgb(15, 15, 16); font-family: monospace; text-align: start;&quot;&gt;, data=df_manova)&lt;/span&gt;&lt;/div&gt;" vertex="1" visible="0">
